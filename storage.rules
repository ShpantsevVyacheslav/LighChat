rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    /** Роль admin в Firestore (как в firestore.rules). */
    function isFirestoreAdmin() {
      return signedIn()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function conversationParticipants(convId) {
      return firestore.get(/databases/(default)/documents/conversations/$(convId)).data.participantIds;
    }

    function isSecretChat(convId) {
      return firestore.get(/databases/(default)/documents/conversations/$(convId)).data.secretChat.enabled == true;
    }

    function hasActiveSecretChatAccess(convId) {
      return firestore.exists(/databases/(default)/documents/conversations/$(convId)/secretAccess/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/conversations/$(convId)/secretAccess/$(request.auth.uid)).data.expiresAtTs > request.time;
    }

    function hasActiveSecretMediaKeyGrant(convId, messageId, fileId) {
      let gid = request.auth.uid + '__' + messageId + '__' + fileId;
      return firestore.exists(/databases/(default)/documents/conversations/$(convId)/secretMediaKeyGrants/$(gid))
        && firestore.get(/databases/(default)/documents/conversations/$(convId)/secretMediaKeyGrants/$(gid)).data.expiresAtTs > request.time;
    }

    function isConversationMember(convId) {
      return signedIn()
        && request.auth.uid in conversationParticipants(convId)
        && (!isSecretChat(convId) || hasActiveSecretChatAccess(convId));
    }

    // SECURITY: defense against (1) storage-quota DoS via huge uploads and
    // (2) firebasestorage.googleapis.com hosting attacker-supplied HTML/SVG
    // (which would be served with the user-controlled Content-Type, enabling
    // XSS at the storage origin). 220 MiB matches our largest legitimate
    // attachment (long video). Allow common chat media + PDF; reject HTML/SVG.
    function isAcceptableChatMediaSize() {
      return request.resource.size < 220 * 1024 * 1024;
    }
    function isAcceptableChatMediaType() {
      return request.resource.contentType is string
        && (request.resource.contentType.matches('image/(jpeg|png|gif|webp|heic|heif)')
            || request.resource.contentType.matches('video/(mp4|webm|quicktime|x-matroska)')
            || request.resource.contentType.matches('audio/(mpeg|mp4|aac|ogg|wav|webm|x-m4a)')
            || request.resource.contentType == 'application/pdf'
            || request.resource.contentType == 'application/octet-stream');
    }
    function isAcceptableImageSize() {
      return request.resource.size < 16 * 1024 * 1024;
    }
    function isAcceptableImageType() {
      return request.resource.contentType is string
        && request.resource.contentType.matches('image/(jpeg|png|gif|webp|heic|heif)');
    }

    /** Статика звонка — без JWT в клиенте для первого запроса. */
    match /audio/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    /** Фоны каталога встреч (только чтение из приложения). */
    match /meeting-assets/{allPaths=**} {
      allow read: if signedIn();
      allow write: if false;
    }

    /** Вложения чата и тредов: только участники диалога. */
    match /chat-attachments/{conversationId}/{allPaths=**} {
      allow read: if isConversationMember(conversationId);
      // delete не требует resource.contentType/size; create+update — требуют.
      allow delete: if isConversationMember(conversationId);
      allow write: if isConversationMember(conversationId)
        && isAcceptableChatMediaSize()
        && isAcceptableChatMediaType();
    }

    /**
     * E2EE v2 — зашифрованные вложения (шифрованные чанки + inline/соседние метаданные).
     * Доступ только участникам диалога; серверные триггеры (transcode) сюда не лезут,
     * поэтому пути обязаны отличаться от plaintext `chat-attachments/`.
     */
    // Secret chat hard media views: require a short-lived per-file key-grant for reads.
    match /chat-attachments-enc/{conversationId}/{messageId}/{fileId}/{allPaths=**} {
      allow read: if isConversationMember(conversationId)
        && (!isSecretChat(conversationId) || hasActiveSecretMediaKeyGrant(conversationId, messageId, fileId));
      allow delete: if isConversationMember(conversationId);
      // E2EE chunks have application/octet-stream content-type — covered by our allow-list.
      allow write: if isConversationMember(conversationId)
        && isAcceptableChatMediaSize();
    }

    // Fallback for any other E2EE path under chat-attachments-enc.
    match /chat-attachments-enc/{conversationId}/{allPaths=**} {
      allow read: if isConversationMember(conversationId);
      allow delete: if isConversationMember(conversationId);
      allow write: if isConversationMember(conversationId)
        && isAcceptableChatMediaSize();
    }

    match /group-avatars/{conversationId}/{allPaths=**} {
      allow read: if signedIn();
      allow delete: if isConversationMember(conversationId);
      allow write: if isConversationMember(conversationId)
        && isAcceptableImageSize() && isAcceptableImageType();
    }

    match /avatars/{userId}/{allPaths=**} {
      allow read: if signedIn();
      allow delete: if signedIn() && (request.auth.uid == userId || isFirestoreAdmin());
      allow write: if signedIn() && (request.auth.uid == userId || isFirestoreAdmin())
        && isAcceptableImageSize() && isAcceptableImageType();
    }

    match /wallpapers/{userId}/{allPaths=**} {
      allow read: if signedIn();
      allow delete: if signedIn() && request.auth.uid == userId;
      allow write: if signedIn() && request.auth.uid == userId
        && isAcceptableImageSize() && isAcceptableImageType();
    }

    match /users/{userId}/sticker-packs/{allPaths=**} {
      allow read: if signedIn();
      allow delete: if signedIn() && request.auth.uid == userId;
      allow write: if signedIn() && request.auth.uid == userId
        && isAcceptableImageSize() && isAcceptableImageType();
    }

    /** Общие стикеры каталога (только админ записывает). */
    match /public/sticker-packs/{allPaths=**} {
      allow read: if signedIn();
      allow delete: if isFirestoreAdmin();
      allow write: if isFirestoreAdmin()
        && isAcceptableImageSize() && isAcceptableImageType();
    }

    match /users/{userId}/backgrounds/{allPaths=**} {
      allow read: if signedIn();
      allow delete: if signedIn() && request.auth.uid == userId;
      allow write: if signedIn() && request.auth.uid == userId
        && isAcceptableImageSize() && isAcceptableImageType();
    }

    /**
     * Чат встречи (не привязан к conversations/). SECURITY: read оставляем
     * для всех signedIn (кросс-тенант ссылки на ассеты митингов сейчас часть
     * UX-дизайна), но WRITE сужаем до участников митинга — раньше любой
     * залогиненный мог перезаписать вложения чужого митинга.
     */
    match /meeting-attachments/{meetingId}/{allPaths=**} {
      function isMeetingMemberStorage() {
        return signedIn()
          && firestore.exists(/databases/(default)/documents/meetings/$(meetingId)/participants/$(request.auth.uid));
      }
      allow read: if signedIn();
      allow delete: if isMeetingMemberStorage();
      allow write: if isMeetingMemberStorage()
        && isAcceptableChatMediaSize()
        && isAcceptableChatMediaType();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
