{
  "name": "lighchat",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});\" && next dev",
    "build:clean": "node -e \"require('fs').rmSync('.next-desktop',{recursive:true,force:true});\" && env LIGHCHAT_DESKTOP_BUILD=1 next build && node -e \"const fs=require('fs');const p=require('path');const root=p.join('.next-desktop','standalone');const st=p.join(root,'.next-desktop','static');fs.mkdirSync(st,{recursive:true});fs.cpSync(p.join('.next-desktop','static'),st,{recursive:true});const pub=p.join(root,'public');fs.mkdirSync(pub,{recursive:true});fs.cpSync('public',pub,{recursive:true});\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "icons:pwa": "bash scripts/generate-pwa-icons.sh",
    "icons:mobile:from-pwa": "node scripts/sync-mobile-launcher-from-pwa.mjs",
    "brand:mark": "node scripts/transparent-lighchat-mark.mjs && npm run icons:pwa",
    "brand:square-mark": "node scripts/transparent-lighchat-mark.mjs --square-only && npm run icons:pwa",
    "deploy:firestore": "firebase deploy --only firestore:rules",
    "deploy:hosting": "firebase deploy --only hosting",
    "predeploy:clean-next": "node -e \"try { require('fs').rmSync('.next', { recursive: true, force: true }); } catch (e) { if (e.code !== 'ENOENT') throw e; }\"",
    "deploy:hosting:clean": "npm run predeploy:clean-next && firebase deploy --only hosting",
    "deploy:functions-hosting:clean": "npm run predeploy:clean-next && firebase deploy --only functions,hosting",
    "desktop": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "icons:mac": "bash scripts/generate-mac-icon.sh",
    "dist": "npm run build:clean && npm run icons:mac && electron-builder"
  },
  "build": {
    "appId": "com.lighchat.app",
    "productName": "LighChat",
    "includeSubNodeModules": true,
    "directories": {
      "output": "dist_desktop"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LighChat"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon-mac.png"
    },
    "asarUnpack": [
      ".next-desktop/standalone/**"
    ],
    "files": [
      "electron/**/*",
      ".next-desktop/standalone/**/*",
      ".next-desktop/static/**/*",
      "public/**/*",
      "package.json",
      "public/icon.png",
      "build/icon-mac.png",
      {
        "from": ".next-desktop/standalone/node_modules",
        "to": ".next-desktop/standalone/node_modules",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.3",
    "@mediapipe/selfie_segmentation": "^0.1.1675465747",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tiptap/extension-bubble-menu": "^2.11.5",
    "@tiptap/extension-link": "^2.11.5",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-underline": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "dompurify": "^3.3.3",
    "embla-carousel-react": "^8.6.0",
    "emoji-picker-react": "^4.19.1",
    "firebase": "^10.14.1",
    "firebase-admin": "^12.1.1",
    "hash-wasm": "^4.12.0",
    "heic2any": "^0.0.4",
    "lucide-react": "^0.475.0",
    "next": "^14.2.5",
    "next-themes": "^0.3.0",
    "open-graph-scraper": "^6.8.2",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-day-picker": "^9.11.3",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.5.7",
    "react-hook-form": "^7.54.2",
    "react-virtuoso": "^4.12.3",
    "react-zoom-pan-pinch": "^3.6.1",
    "simple-peer": "^9.11.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "thumbhash": "^0.1.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/simple-peer": "^9.11.8",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "firebase-tools": "^14.27.0",
    "postcss": "^8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wait-on": "^7.2.0"
  }
}
