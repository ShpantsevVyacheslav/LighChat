{
  "name": "lighchat",
  "version": "0.1.0",
  "private": true,
  "description": "LighChat — приватный мессенджер с E2E-шифрованием, мульти-девайс через QR и кастомными темами для веб, PWA и нативных Flutter-клиентов (iOS/Android/macOS/Windows/Linux).",
  "homepage": "https://lighchat.online",
  "repository": {
    "type": "git",
    "url": "https://github.com/ShpantsevVyacheslav/LighChat"
  },
  "bugs": {
    "url": "https://github.com/ShpantsevVyacheslav/LighChat/issues"
  },
  "keywords": [
    "messenger",
    "chat",
    "video-conferencing",
    "e2e-encryption",
    "webrtc",
    "flutter",
    "nextjs",
    "firebase",
    "pwa",
    "qr-auth",
    "private-messenger"
  ],
  "author": "LighChat Team",
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});\" && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons:pwa": "bash scripts/generate-pwa-icons.sh",
    "icons:mobile:from-pwa": "node scripts/sync-mobile-launcher-from-pwa.mjs",
    "brand:mark": "node scripts/transparent-lighchat-mark.mjs && npm run icons:pwa",
    "brand:square-mark": "node scripts/transparent-lighchat-mark.mjs --square-only && npm run icons:pwa",
    "deploy:firestore": "firebase deploy --only firestore:rules",
    "deploy:hosting": "firebase deploy --only hosting",
    "predeploy:clean-next": "node -e \"try { require('fs').rmSync('.next', { recursive: true, force: true }); } catch (e) { if (e.code !== 'ENOENT') throw e; }\"",
    "deploy:hosting:clean": "npm run predeploy:clean-next && firebase deploy --only hosting",
    "deploy:functions-hosting:clean": "npm run predeploy:clean-next && firebase deploy --only functions,hosting",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.3",
    "@mediapipe/selfie_segmentation": "^0.1.1675465747",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tiptap/extension-bubble-menu": "^2.11.5",
    "@tiptap/extension-link": "^2.11.5",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-underline": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "@yudiel/react-qr-scanner": "^2.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "dompurify": "^3.3.3",
    "embla-carousel-react": "^8.6.0",
    "emoji-picker-react": "^4.19.1",
    "firebase": "^12.13.0",
    "firebase-admin": "^12.1.1",
    "hash-wasm": "^4.12.0",
    "heic2any": "^0.0.4",
    "lucide-react": "^0.475.0",
    "next": "^15.5.18",
    "next-themes": "^0.3.0",
    "open-graph-scraper": "^6.8.2",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-day-picker": "^9.11.3",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.5.7",
    "react-hook-form": "^7.54.2",
    "react-virtuoso": "^4.12.3",
    "react-zoom-pan-pinch": "^3.6.1",
    "simple-peer": "^9.11.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "thumbhash": "^0.1.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/simple-peer": "^9.11.8",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.18",
    "firebase-tools": "^14.27.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^2.1.9"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": "eslint --fix",
    "functions/**/*.{ts,js}": "bash -c 'cd functions && npx eslint --fix \"$@\"' _"
  }
}
