## Extension: firebase/firestore-bigquery-export@0.3.2
## Mirrors Firestore collection `analyticsEvents` into BigQuery for
## historical analytics. Auto-installed in project-72b24 via Firebase
## Console — этот файл фиксирует параметры под управление `firebase
## deploy --only extensions` и code review.

## Locations (cannot be reconfigured after install)
LOCATION=us-central1
BIGQUERY_DATASET_LOCATION=us-central1
BIGQUERY_PROJECT_ID=project-72b24

## Firestore source
DATABASE=(default)
DATABASE_REGION=us-central1
COLLECTION_PATH=analyticsEvents
WILDCARD_IDS=false

## BigQuery destination
DATASET_ID=firestore_export
TABLE_ID=analytics_events

## Partitioning — DAY (cannot change after install without recreating table)
TABLE_PARTITIONING=DAY
TIME_PARTITIONING_FIELD=
TIME_PARTITIONING_FIRESTORE_FIELD=
TIME_PARTITIONING_FIELD_TYPE=omit

## Clustering — none (default; can add later: e.g. `timestamp,document_id`)
CLUSTERING=

## Throughput
MAX_DISPATCHES_PER_SECOND=100

## View — regular (not materialized; sufficient at our scale)
VIEW_TYPE=view
MAX_STALENESS=
REFRESH_INTERVAL_MINUTES=60

## Failure handling
BACKUP_COLLECTION=
TRANSFORM_FUNCTION=

## Performance flags
USE_NEW_SNAPSHOT_QUERY_SYNTAX=yes
EXCLUDE_OLD_DATA=yes

## Security
KMS_KEY_NAME=

## Retry/log
MAX_ENQUEUE_ATTEMPTS=3
LOG_LEVEL=warn
