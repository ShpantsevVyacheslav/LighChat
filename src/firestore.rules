
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    /** Роль из Firestore: поле role (строка) должно быть ровно «admin». */
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isMeetingHost(meetingId) {
      return isSignedIn() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
    }

    /**
     * Host или пользователь, попавший в `adminIds` митинга.
     * Требует существования meetings/{meetingId}; подколлекции вызывают функцию только в контексте
     * существующего митинга (иначе parent-get кидает denied, что и нужно).
     */
    function isMeetingAdmin(meetingId) {
      let m = get(/databases/$(database)/documents/meetings/$(meetingId)).data;
      return isSignedIn()
        && (m.hostId == request.auth.uid
            || (m.adminIds is list && (request.auth.uid in m.adminIds)));
    }

    /**
     * Участник комнаты: существует собственный participants/{uid} — ставится после входа
     * (в т.ч. гостем после одобрения). Используется для разрешения signals/messages/polls
     * и чтения списка других участников.
     */
    function isMeetingMember(meetingId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(request.auth.uid));
    }

    /**
     * Гость, чей `requests/{uid}` одобрен хостом. Нужен, чтобы гость мог создать свой
     * `participants/{uid}` сразу после апрува (до того, как он стал member).
     */
    function isMeetingGuestApproved(meetingId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/meetings/$(meetingId)/requests/$(request.auth.uid))
        && get(/databases/$(database)/documents/meetings/$(meetingId)/requests/$(request.auth.uid)).data.status == 'approved';
    }

    /** Открытый (не приватный) митинг: вход без апрува. */
    function isMeetingPublic(meetingId) {
      return exists(/databases/$(database)/documents/meetings/$(meetingId))
        && get(/databases/$(database)/documents/meetings/$(meetingId)).data.isPrivate == false;
    }

    /**
     * Сам пользователь не может менять блокировку, произвольную смену роли, soft-delete и квоту — только админ.
     * Исключение: OAuth-bridge (Telegram/Яндекс) получает из `onUserCreated` `role: null` (нет email/phone в Auth);
     * клиент один раз выставляет `worker` — см. `finalizeOAuthCredential` в use-auth.
     */
    function userSensitiveKeysChanged(userId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let roleWasUnset =
        !resource.data.keys().hasAny(['role']) || resource.data.role == null;
      let allowWorkerBootstrap =
        request.auth.uid == userId
        && roleWasUnset
        && request.resource.data.role == 'worker';
      return changed.hasAny(['accountBlock', 'deletedAt', 'storageQuotaBytes'])
        || (changed.hasAny(['role']) && !allowWorkerBootstrap);
    }

    /**
     * Участник по полю participantIds (list или map ключей).
     * Не используем data.keys().hasAny(['participantIds']): при list-запросах с array-contains
     * правила Firestore должны сопоставить фильтр запроса с условием; лишняя проверка keys()
     * ломает это сопоставление и даёт permission-denied на весь query (см. ensureSavedMessagesChat / список чатов).
     */
    function uidIsConversationParticipantFromData(data) {
      return (data.participantIds is list && data.participantIds.hasAny([request.auth.uid]))
        || (data.participantIds is map && request.auth.uid in data.participantIds);
    }

    function isSavedMessagesConversationData(data) {
      return data.participantIds is list && data.participantIds.size() == 1;
    }

    /**
     * Разрешаем `get` для ещё несуществующих детерминированных id чатов,
     * чтобы клиент мог идемпотентно создавать `saved_*`/`dm_*` через get+create
     * без permission-denied на шаге preflight-чтения.
     */
    function canReadMissingConversationById(conversationId) {
      return request.method == 'get' && (
        conversationId.matches('^saved_[0-9]+:.*$') ||
        conversationId.matches('^dm_.*$')
      );
    }

    /** Запасной путь, пока CF ещё не создала members/{uid} (миллисекунды после создания чата). */
    function conversationMemberFallbackFromParent(conversationId) {
      return exists(/databases/$(database)/documents/conversations/$(conversationId))
        && uidIsConversationParticipantFromData(
          get(/databases/$(database)/documents/conversations/$(conversationId)).data
        );
    }

    /**
     * Основной путь: conversations/{id}/members/{auth.uid} (Cloud Functions).
     * Fallback: participantIds на parent — только если индекса ещё нет.
     */
    function isConversationMember(conversationId) {
      return isSignedIn()
        && (
          exists(/databases/$(database)/documents/conversations/$(conversationId)/members/$(request.auth.uid))
          || conversationMemberFallbackFromParent(conversationId)
        );
    }

    /**
     * Блокирующий заблокировал blockedUid: маркер `users/{blockerUid}/outgoingBlocks/{blockedUid}`
     * (синхронизирует CF при изменении `blockedUserIds`). Раньше читали `users/{blocker}` через get —
     * правило чтения профиля запрещало get заблокированному, из‑за чего в правилах получался
     * permission-denied вместо корректной проверки блока (в т.ч. на `conversations/.../messages`).
     */
    function userBlocks(blockerUid, blockedUid) {
      return exists(/databases/$(database)/documents/users/$(blockerUid)/outgoingBlocks/$(blockedUid));
    }

    function isDmTwoPartyConversationData(data) {
      return data.isGroup != true
        && data.participantIds is list
        && data.participantIds.size() == 2;
    }

    function dmPartnerUidFromData(data, me) {
      let ids = data.participantIds;
      return ids[0] == me ? ids[1] : ids[0];
    }

    /** Личный чат: собеседник заблокировал текущего — скрываем диалог для заблокированного. */
    function isDmHiddenForViewerFromConvData(data) {
      return isDmTwoPartyConversationData(data)
        && userBlocks(dmPartnerUidFromData(data, request.auth.uid), request.auth.uid);
    }

    /** Личный чат: либо я заблокировал собеседника, либо он меня — не отправляем сообщения. */
    function dmPairMessagingDeniedFromConvData(data) {
      return isDmTwoPartyConversationData(data)
        && (
          userBlocks(request.auth.uid, dmPartnerUidFromData(data, request.auth.uid))
          || userBlocks(dmPartnerUidFromData(data, request.auth.uid), request.auth.uid)
        );
    }

    function dmPairDeniedFromParticipantCreateData(data) {
      return data.isGroup != true
        && data.participantIds is list
        && data.participantIds.size() == 2
        && (
          userBlocks(data.participantIds[0], data.participantIds[1])
          || userBlocks(data.participantIds[1], data.participantIds[0])
        );
    }

    function conversationData(conversationId) {
      return get(/databases/$(database)/documents/conversations/$(conversationId)).data;
    }

    function isSecretChatConversationData(data) {
      return data.secretChat is map && data.secretChat.enabled == true;
    }

    function hasActiveSecretChatAccess(conversationId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/conversations/$(conversationId)/secretAccess/$(request.auth.uid))
        && get(/databases/$(database)/documents/conversations/$(conversationId)/secretAccess/$(request.auth.uid)).data.expiresAtTs > request.time;
    }

    function canReadSecretChat(conversationId, data) {
      return !isSecretChatConversationData(data) || hasActiveSecretChatAccess(conversationId);
    }

    /** Звонок 1:1: запрет, если кто-то из пары заблокировал другого. */
    function callPairBlockedCreate(callerId, receiverId) {
      return userBlocks(callerId, receiverId) || userBlocks(receiverId, callerId);
    }

    /** Участник не может менять квоту хранилища диалога; админ — может (ветка isAdmin в allow update). */
    function conversationStorageQuotaUnchanged() {
      let beforeHas = resource.data.keys().hasAny(['storageQuotaBytes']);
      let afterHas = request.resource.data.keys().hasAny(['storageQuotaBytes']);
      let qBefore = beforeHas ? resource.data.storageQuotaBytes : null;
      let qAfter = afterHas ? request.resource.data.storageQuotaBytes : null;
      return qAfter == qBefore;
    }

    /** Создатель или админ группы (для полей исчезающих сообщений на `conversations`). */
    function isGroupAdminOrCreatorFromConvData(data) {
      let uid = request.auth.uid;
      let creator = data.createdByUserId;
      let admins = data.adminIds is list ? data.adminIds : [];
      return (creator is string && uid == creator)
        || (admins is list && uid in admins);
    }

    /**
     * В группе менять `disappearingMessageTtlSec` / метаданные смены могут только создатель и adminIds.
     * В личных чатах — любой участник (как и прочие поля parent).
     */
    function conversationDisappearingUpdateAllowed() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let touches = changed.hasAny([
        'disappearingMessageTtlSec',
        'disappearingMessagesUpdatedAt',
        'disappearingMessagesUpdatedBy',
      ]);
      return !touches
        || resource.data.isGroup != true
        || isGroupAdminOrCreatorFromConvData(resource.data);
    }

    /** Secret chat settings are server-controlled (callable -> Admin SDK). */
    function conversationSecretChatUnchanged() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return !changed.hasAny(['secretChat']);
    }

    /** Клиент не создаёт `expireAt` (выставляет только Admin SDK + TTL). */
    function chatMessageCreateWithoutExpireAt() {
      return !request.resource.data.keys().hasAny(['expireAt']);
    }

    /** Клиент не добавляет/не меняет/не удаляет `expireAt` на сообщениях. */
    function chatMessageExpireAtUnchanged() {
      let had = resource.data.keys().hasAny(['expireAt']);
      let will = request.resource.data.keys().hasAny(['expireAt']);
      return (!had && !will)
        || (had && will && request.resource.data.expireAt == resource.data.expireAt);
    }

    /** Участник активного звонка (документ call уже существует). */
    function isCallParticipantForExisting(callId) {
      let d = get(/databases/$(database)/documents/calls/$(callId)).data;
      return isSignedIn()
        && (request.auth.uid == d.callerId || request.auth.uid == d.receiverId);
    }

    /**
     * Индекс уникальности телефона / email / логина для регистрации до входа.
     * Заполняется только Cloud Functions (Admin SDK); клиент только get.
     */
    match /registrationIndex/{docId} {
      /**
       * До входа (регистрация) — чтение без auth. После входа: если владелец
       * индекса заблокировал читателя, не раскрываем привязку phone/email/login → uid.
       */
      allow read: if request.auth == null
        || (
          isSignedIn()
          && resource.data.keys().hasAll(['uid'])
          && resource.data.uid is string
          && (
            !exists(/databases/$(database)/documents/users/$(resource.data.uid))
            || !get(/databases/$(database)/documents/users/$(resource.data.uid)).data.keys().hasAny(['blockedUserIds'])
            || !(get(/databases/$(database)/documents/users/$(resource.data.uid)).data.blockedUserIds is list)
            || !(request.auth.uid in get(/databases/$(database)/documents/users/$(resource.data.uid)).data.blockedUserIds)
          )
        );
      allow write: if false;
    }

    /**
     * Общие стикерпаки для всех вошедших пользователей.
     * Запись только у admin (поле users/{uid}.role == «admin»).
     */
    match /publicStickerPacks/{packId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      match /items/{itemId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }

    match /users/{userId} {
      /**
       * Чтение чужого профиля запрещено, если владелец добавил читателя в blockedUserIds.
       */
      allow read: if isSignedIn() && (
        request.auth.uid == userId
        || !resource.data.keys().hasAny(['blockedUserIds'])
        || !(resource.data.blockedUserIds is list)
        || !(request.auth.uid in resource.data.blockedUserIds)
      );
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if isSignedIn() && (
        isAdmin() ||
        (request.auth.uid == userId && !userSensitiveKeysChanged(userId))
      );
      allow delete: if false;

      /**
       * Маркеры исходящих блокировок (зеркало `blockedUserIds`). Читать может блокирующий или
       * заблокированный — второму нужен `exists` в правилах без чтения полного `users/{blocker}`.
       * Запись только через Admin SDK (Cloud Functions).
       */
      match /outgoingBlocks/{blockedUserId} {
        allow read: if isSignedIn() && (
          request.auth.uid == userId
          || request.auth.uid == blockedUserId
        );
        allow write: if false;
      }

      match /notifications/{notificationId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      match /stickerPacks/{packId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
        match /items/{itemId} {
          allow read, write: if isSignedIn() && request.auth.uid == userId;
        }
      }

      /**
       * v2: публичные ключи всех устройств пользователя. Read — любой
       * авторизованный (нужно, чтобы слать wrap каждому устройству собеседника),
       * write — только владелец `userId`. См. docs/arcitecture/07-e2ee-v2-protocol.md §5.1.
       *
       * Legacy `users/{uid}/e2ee/{docId}` (v1) удалён в Phase 10 cleanup.
       */
      match /e2eeDevices/{deviceId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == userId;
      }

      /**
       * v2: password-backup обёрнутого приватника. Только владелец видит
       * и пишет свои backup-doc'и. См. RFC §5.2.
       */
      match /e2eeBackups/{backupId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      /**
       * v2: эфемерная QR-pairing сессия, TTL 10 минут (чистится scheduled CF).
       * Только владелец видит и пишет. См. RFC §5.3 и §6.7.
       */
      match /e2eePairingSessions/{sessionId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      /** Реестр устройств пользователя: текущие клиентские сессии, active/lastSeen/fcm. */
      match /devices/{deviceId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      /** Избранные сообщения в чатах (только владелец). */
      match /starredChatMessages/{docId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId
          && request.resource.data.conversationId is string
          && request.resource.data.messageId is string
          && request.resource.data.createdAt is string
          && isConversationMember(request.resource.data.conversationId);
        allow update: if false;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      /** Персональные настройки конкретного чата (только владелец и участник чата). */
      match /chatConversationPrefs/{conversationId} {
        allow read, delete: if isSignedIn() && request.auth.uid == userId
          && isConversationMember(conversationId);
        allow create, update: if isSignedIn() && request.auth.uid == userId
          && isConversationMember(conversationId)
          && request.resource.data.conversationId == conversationId;
      }
    }

    /**
     * Митинги (video-конференции):
     *   - `meetings/{id}` — публичный для чтения любому залогиненному (включая анонимного
     *     гостя, открывшего /meetings/{id}; иначе JoinMeeting получает permission-denied
     *     ещё до подачи заявки). Создание/изменение/удаление — только host/admin.
     *   - `signals/*`, `messages/*`, `polls/*` — приватно для участников (есть participants/{uid}).
     *   - `participants/{uid}` — запись только своего документа, и только если митинг открытый,
     *     гость одобрен, либо пользователь — host/admin. Чтение списка — только участникам.
     *   - `requests/{uid}` — self-create/heartbeat, host-update (approve/deny через callable).
     */
    match /meetings/{meetingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.id == meetingId;
      allow update: if isSignedIn() && (
        resource.data.hostId == request.auth.uid
        || (resource.data.adminIds is list && (request.auth.uid in resource.data.adminIds))
      );
      allow delete: if isSignedIn() && resource.data.hostId == request.auth.uid;

      match /signals/{signalId} {
        allow read: if isMeetingMember(meetingId)
          && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
        allow create: if isMeetingMember(meetingId)
          && request.resource.data.from == request.auth.uid;
        allow delete: if isMeetingMember(meetingId)
          && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
      }

      match /participants/{participantId} {
        allow read: if isMeetingMember(meetingId)
          || isMeetingAdmin(meetingId)
          || request.auth.uid == participantId;
        allow create: if isSignedIn() && request.auth.uid == participantId && (
          isMeetingPublic(meetingId)
          || isMeetingGuestApproved(meetingId)
          || isMeetingAdmin(meetingId)
        );
        allow update: if isSignedIn() && (
          request.auth.uid == participantId
          || isMeetingAdmin(meetingId)
        );
        allow delete: if isSignedIn() && (
          request.auth.uid == participantId
          || isMeetingAdmin(meetingId)
        );
      }

      match /requests/{userId} {
        allow read: if isSignedIn() && (
          request.auth.uid == userId
          || isMeetingAdmin(meetingId)
        );
        allow create, update, delete: if isSignedIn() && (
          request.auth.uid == userId
          || isMeetingAdmin(meetingId)
        );
      }

      match /messages/{messageId} {
        allow read: if isMeetingMember(meetingId);
        allow create: if isMeetingMember(meetingId)
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isMeetingMember(meetingId) && (
          resource.data.senderId == request.auth.uid
          || isMeetingAdmin(meetingId)
        );
      }

      match /polls/{pollId} {
        allow read: if isMeetingMember(meetingId);
        allow write: if isMeetingMember(meetingId);
      }
    }

    match /userChats/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /userContacts/{userId} {
      allow get, create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;

      /**
       * Локальный индекс телефонной книги для автосопоставления (phone/email):
       * `userContacts/{uid}/deviceLookup/{registrationIndexKey}`.
       * Пишется только владельцем uid; читает только владелец.
       */
      match /deviceLookup/{lookupId} {
        allow read, create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /userCalls/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /userMeetings/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Games (in-chat mini apps):
     * - Документы создаются/обновляются только через Cloud Functions (Admin SDK).
     * - Клиенты читают только свои игры (uid ∈ playerIds).
     */
    match /games/{gameId} {
      allow read: if isSignedIn()
        && resource.data.playerIds is list
        && resource.data.playerIds.hasAny([request.auth.uid]);
      allow write: if false;

      /** Private hands: only the owner reads. */
      match /privateHands/{userId} {
        allow read: if isSignedIn()
          && request.auth.uid == userId
          && exists(/databases/$(database)/documents/games/$(gameId))
          && get(/databases/$(database)/documents/games/$(gameId)).data.playerIds is list
          && get(/databases/$(database)/documents/games/$(gameId)).data.playerIds.hasAny([request.auth.uid]);
        allow write: if false;
      }

      match /{subPath=**} {
        allow read: if isSignedIn()
          && exists(/databases/$(database)/documents/games/$(gameId))
          && get(/databases/$(database)/documents/games/$(gameId)).data.playerIds is list
          && get(/databases/$(database)/documents/games/$(gameId)).data.playerIds.hasAny([request.auth.uid]);
        allow write: if false;
      }
    }

    match /tournaments/{tournamentId} {
      allow read: if isSignedIn()
        && resource.data.conversationId is string
        && isConversationMember(resource.data.conversationId);
      allow write: if false;

      match /games/{gameId} {
        allow read: if isSignedIn()
          && exists(/databases/$(database)/documents/tournaments/$(tournamentId))
          && isConversationMember(get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.conversationId);
        allow write: if false;
      }
    }

    match /conversations/{conversationId} {
      /**
       * Одно выражение: list-query по коллекции с array-contains в клиенте не используется (список чатов — userChats + doc).
       * Раздельные allow read ломали вложенный get(parent) в правилах подколлекций (messages/polls/typing).
       * Админ: полный list по conversations (панель «Хранилище» / admin-storage-stats-panel).
       *
       * Чтение parent-документа: participantIds **или** индекс members/{uid} (создаёт CF). Иначе после появления id в
       * userChats подписка useConversationsByDocumentIds могла получать permission-denied, если поле parent
       * временно не сопоставимо с правилами, а members уже записан (см. onConversationCreated).
       */
      allow read: if isSignedIn() && (
        (
          resource != null && (
            isSavedMessagesConversationData(resource.data)
              ? uidIsConversationParticipantFromData(resource.data)
              : (
                  isAdmin() ||
                  exists(/databases/$(database)/documents/conversations/$(conversationId)/members/$(request.auth.uid)) ||
                  (
                    uidIsConversationParticipantFromData(resource.data)
                    && !isDmHiddenForViewerFromConvData(resource.data)
                  )
                )
          )
        ) ||
        (resource == null && canReadMissingConversationById(conversationId))
      );
      allow create: if isSignedIn()
        && uidIsConversationParticipantFromData(request.resource.data)
        && request.resource.data.participantIds is list
        && request.resource.data.participantIds.size() >= 1
        && !dmPairDeniedFromParticipantCreateData(request.resource.data);
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          uidIsConversationParticipantFromData(resource.data)
          && conversationStorageQuotaUnchanged()
          && conversationDisappearingUpdateAllowed()
          && conversationSecretChatUnchanged()
        )
      );
      allow delete: if isSignedIn() && uidIsConversationParticipantFromData(resource.data);

      /** Индекс участников для правил подколлекций; запись только с сервера (Admin SDK). */
      match /members/{memberId} {
        allow read: if isSignedIn() && request.auth.uid == memberId;
        allow write: if false;
      }

      /** Game lobbies for a conversation (server-write). */
      match /gameLobbies/{gameId} {
        allow read: if isConversationMember(conversationId)
          && canReadSecretChat(conversationId, conversationData(conversationId))
          && !isDmHiddenForViewerFromConvData(conversationData(conversationId));
        allow write: if false;
      }

      match /tournaments/{tournamentId} {
        allow read: if isConversationMember(conversationId)
          && canReadSecretChat(conversationId, conversationData(conversationId))
          && !isDmHiddenForViewerFromConvData(conversationData(conversationId));
        allow write: if false;
      }

      /**
       * Индикатор «печатает…». Читать/писать — только участникам.
       * Удаление своего документа разрешено любому вошедшему с тем же uid: клиент чистит typing
       * при смене чата; строгая проверка member иногда ломалась на старых/групповых документах.
       */
      match /typing/{typingUserId} {
        allow read: if isConversationMember(conversationId)
          && canReadSecretChat(conversationId, conversationData(conversationId))
          && !isDmHiddenForViewerFromConvData(conversationData(conversationId));
        allow create, update: if isConversationMember(conversationId)
          && canReadSecretChat(conversationId, conversationData(conversationId))
          && request.auth.uid == typingUserId
          && !dmPairMessagingDeniedFromConvData(conversationData(conversationId));
        allow delete: if isSignedIn() && request.auth.uid == typingUserId;
      }

      match /messages/{messageId} {
        allow read: if isConversationMember(conversationId)
          && canReadSecretChat(conversationId, conversationData(conversationId))
          && !isDmHiddenForViewerFromConvData(conversationData(conversationId));
        // Phase 8: разрешаем клиенту писать system-маркер E2EE
        // (senderId = '__system__') при условии, что в документе есть
        // `systemEvent` c допустимым `type`. Обычные сообщения по-прежнему
        // должны иметь senderId == auth.uid.
        allow create: if isConversationMember(conversationId)
          && canReadSecretChat(conversationId, conversationData(conversationId))
          && !dmPairMessagingDeniedFromConvData(conversationData(conversationId))
          && chatMessageCreateWithoutExpireAt()
          && (
          request.resource.data.senderId == request.auth.uid
          || (
            request.resource.data.senderId == '__system__'
            && request.resource.data.systemEvent is map
            && request.resource.data.systemEvent.type is string
          )
        );
        allow update: if isConversationMember(conversationId)
          && canReadSecretChat(conversationId, conversationData(conversationId))
          && chatMessageExpireAtUnchanged();
        allow delete: if isConversationMember(conversationId)
          && canReadSecretChat(conversationId, conversationData(conversationId));

        match /{subPath=**} {
          allow read: if isConversationMember(conversationId)
            && canReadSecretChat(conversationId, conversationData(conversationId))
            && !isDmHiddenForViewerFromConvData(conversationData(conversationId));
          allow create: if isConversationMember(conversationId)
            && canReadSecretChat(conversationId, conversationData(conversationId))
            && !isDmHiddenForViewerFromConvData(conversationData(conversationId))
            && !dmPairMessagingDeniedFromConvData(conversationData(conversationId))
            && chatMessageCreateWithoutExpireAt();
          allow update: if isConversationMember(conversationId)
            && canReadSecretChat(conversationId, conversationData(conversationId))
            && !isDmHiddenForViewerFromConvData(conversationData(conversationId))
            && !dmPairMessagingDeniedFromConvData(conversationData(conversationId))
            && chatMessageExpireAtUnchanged();
          allow delete: if isConversationMember(conversationId)
            && canReadSecretChat(conversationId, conversationData(conversationId))
            && !isDmHiddenForViewerFromConvData(conversationData(conversationId))
            && !dmPairMessagingDeniedFromConvData(conversationData(conversationId));
        }
      }

      match /polls/{pollId} {
        allow read: if isConversationMember(conversationId)
          && canReadSecretChat(conversationId, conversationData(conversationId))
          && !isDmHiddenForViewerFromConvData(conversationData(conversationId));
        allow write: if isConversationMember(conversationId)
          && canReadSecretChat(conversationId, conversationData(conversationId))
          && !isDmHiddenForViewerFromConvData(conversationData(conversationId))
          && !dmPairMessagingDeniedFromConvData(conversationData(conversationId));
      }

      /** Эпохи ключей E2E (ciphertext обёрток на участника). */
      match /e2eeSessions/{sessionId} {
        allow read: if isConversationMember(conversationId)
          && canReadSecretChat(conversationId, conversationData(conversationId))
          && !isDmHiddenForViewerFromConvData(conversationData(conversationId));
        allow write: if isConversationMember(conversationId)
          && canReadSecretChat(conversationId, conversationData(conversationId))
          && !isDmHiddenForViewerFromConvData(conversationData(conversationId))
          && !dmPairMessagingDeniedFromConvData(conversationData(conversationId));
      }

      /** Unlock grants секретного чата: пишет только сервер (callable), читает только владелец. */
      match /secretAccess/{userId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow write: if false;
      }

      /**
       * Secret Chat hard-enforced media view limits.
       * Server writes only; clients can only read relevant docs.
       */
      match /secretMediaViewState/{docId} {
        allow read: if isConversationMember(conversationId)
          && canReadSecretChat(conversationId, conversationData(conversationId))
          && !isDmHiddenForViewerFromConvData(conversationData(conversationId));
        allow write: if false;
      }

      match /secretMediaViewRequests/{docId} {
        allow read: if isConversationMember(conversationId)
          && canReadSecretChat(conversationId, conversationData(conversationId))
          && !isDmHiddenForViewerFromConvData(conversationData(conversationId));
        allow write: if false;
      }

      match /secretMediaKeyGrants/{docId} {
        allow read: if isSignedIn()
          && resource.data.recipientUid == request.auth.uid
          && resource.data.expiresAtTs > request.time
          && isConversationMember(conversationId)
          && canReadSecretChat(conversationId, conversationData(conversationId))
          && !isDmHiddenForViewerFromConvData(conversationData(conversationId));
        allow write: if false;
      }
    }

    match /calls/{callId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.callerId ||
        request.auth.uid == resource.data.receiverId
      );
      allow create: if isSignedIn()
        && request.resource.data.callerId == request.auth.uid
        && request.resource.data.receiverId is string
        && request.resource.data.callerId is string
        && !callPairBlockedCreate(
          request.resource.data.callerId,
          request.resource.data.receiverId
        );
      allow update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.callerId ||
        request.auth.uid == resource.data.receiverId
      );

      match /candidates/{candidateId} {
        allow read, write: if isCallParticipantForExisting(callId);
      }
    }

    /** Не используется клиентом LighChat — закрыто от клиентских запросов. */
    match /departureAddresses/{addressId} {
      allow read, write: if false;
    }

    match /vehicles/{document=**} { allow read, write: if false; }
    match /drivers/{document=**} { allow read, write: if false; }
    match /trips/{document=**} { allow read, write: if false; }
    match /suppliers/{document=**} { allow read, write: if false; }
    match /customers/{document=**} { allow read, write: if false; }
    match /tariffs/{document=**} { allow read, write: if false; }

    match /settings/{document=**} { allow read, write: if false; }

    match /platformSettings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /supportTickets/{ticketId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}
