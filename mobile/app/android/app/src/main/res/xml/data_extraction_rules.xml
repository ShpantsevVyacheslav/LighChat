<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API >= 31) data-extraction policy. Same intent as backup_rules:
  refuse cloud backup AND device-to-device transfer of every category. The
  user re-authenticates on the new device and receives chat history via
  Firestore — there's no value in transferring local caches/drafts.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </device-transfer>
</data-extraction-rules>
