<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>NSLocalNetworkUsageDescription</key>
	<string>LighChat использует локальную сеть для установки прямых peer-to-peer соединений при голосовых и видеозвонках, что улучшает качество связи и снижает задержку.</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>ru</string>
	<key>CFBundleLocalizations</key>
	<array>
		<string>ru</string>
		<string>en</string>
		<string>kk</string>
		<string>uz</string>
		<string>tr</string>
		<string>id</string>
		<string>pt-BR</string>
		<string>es-MX</string>
	</array>
	<key>CFBundleDisplayName</key>
	<string>LighChat</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>LighChat</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.262148817877-eolh9e7k10oa2r77tf3umv7jv1so0vrm</string>
				<string>app-1-262148817877-ios-b3472b836d144249f0335c</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>Чтобы снимать фото и видео для сообщений в чате</string>
	<key>NSContactsUsageDescription</key>
	<string>Чтобы находить знакомых и синхронизировать контакты из телефонной книги</string>
	<key>NSCalendarsWriteOnlyAccessUsageDescription</key>
	<string>Чтобы быстро добавить дату из сообщения в ваш календарь — долгий тап на дате</string>
	<key>NSCalendarsUsageDescription</key>
	<string>Чтобы быстро добавить дату из сообщения в ваш календарь — долгий тап на дате</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Для разблокировки секретных чатов и подтверждения действий в хранилище</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Чтобы отправлять и обновлять геолокацию в чате</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Для записи голосовых сообщений, видео со звуком, а также для голосовых и видеозвонков в чате</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Чтобы сохранять фото и видео из чата в галерею</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Чтобы прикреплять фото и видео из галереи</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Для локальной транскрибации голосовых сообщений на устройстве — без отправки аудио на внешние серверы</string>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneClassName</key>
					<string>UIWindowScene</string>
					<key>UISceneConfigurationName</key>
					<string>flutter</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
					<key>UISceneStoryboardFile</key>
					<string>Main</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<!-- `audio` — фоновое аудио (PiP, music).
		     `voip` — нужен ИМЕННО для того, чтобы AVCaptureSession (камера)
		     не приостанавливалась в фоне на устройствах без поддержки
		     `multitaskingCameraAccessSupported` (старые iPhone и/или
		     ситуации когда WebRTC создаёт session до того, как мы можем
		     выставить флаг). Без этого PiP замерзает на последнем кадре.
		     ВАЖНО: сам plist-ключ `voip` работает на free Apple ID
		     (Personal Team). Что требует paid program ($99/год) — это
		     PushKit VoIP push notifications + `remote-notification`.
		     Их здесь нет — добавим, когда будет paid account. -->
		<string>audio</string>
		<string>voip</string>
	</array>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
