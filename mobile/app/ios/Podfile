# Firebase / cloud_firestore need a recent iOS deployment target.
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  # Статические фреймворки — иначе у FirebaseFirestoreInternal часто ломаются пути к заголовкам
  # (например `Firestore/core/include/firebase/firestore/timestamp.h` not found).
  use_frameworks! :linkage => :static

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      # gRPC-Core bundles zlib; on Apple platforms zutil.h defines OS_CODE twice (generic + Apple),
      # which spams -Wmacro-redefined and can fail builds that treat warnings as errors.
      if target.name == 'gRPC-Core'
        flags = config.build_settings['OTHER_CFLAGS']
        list =
          case flags
          when nil, ''
            ['$(inherited)']
          when Array
            flags.map(&:to_s)
          else
            [flags.to_s]
          end
        list << '-Wno-macro-redefined' unless list.any? { |f| f.include?('macro-redefined') }
        config.build_settings['OTHER_CFLAGS'] = list
      end
      # Prevent stripping FFI symbols used by super_clipboard/super_native_extensions.
      if target.name == 'super_native_extensions'
        config.build_settings['STRIP_STYLE'] = 'non-global'
        config.build_settings['DEAD_CODE_STRIPPING'] = 'NO'
        config.build_settings['STRIP_INSTALLED_PRODUCT'] = 'NO'
      end
    end
  end

  # super_native_extensions ships Rust symbols in static archive.
  # With `use_frameworks! :linkage => :static` they may not be force-loaded
  # into Runner, which leads to undefined symbols at link time.
  installer.aggregate_targets.each do |aggregate_target|
    user_project = aggregate_target.user_project
    next if user_project.nil?
    user_project.native_targets.each do |target|
      next unless target.name == 'Runner'
      target.build_configurations.each do |config|
        # iOS Archive/TestFlight may strip FFI-exported symbols, leading to:
        # `Failed to lookup symbol 'super_native_extensions_init_message_channel_context'`.
        # This keeps global symbols while still allowing size optimizations.
        config.build_settings['STRIP_STYLE'] = 'non-global'
        config.build_settings['DEAD_CODE_STRIPPING'] = 'NO'
        config.build_settings['STRIP_INSTALLED_PRODUCT'] = 'NO'

        ldflags = config.build_settings['OTHER_LDFLAGS']
        values =
          case ldflags
          when nil
            ['$(inherited)']
          when Array
            ldflags.map(&:to_s)
          else
            [ldflags.to_s]
          end
        # Two separate argv entries — a single combined "-force_load ..." string can confuse Xcode
        # (it may treat a lone "-force_load" pass as an input file path `ios/-force_load`).
        lib_path = '${PODS_CONFIGURATION_BUILD_DIR}/super_native_extensions/libsuper_native_extensions.a'
        values = values.reject do |v|
          s = v.to_s
          s.include?('libsuper_native_extensions.a') || s == '-force_load' || s.start_with?('-force_load ')
        end
        values << '-force_load'
        values << lib_path
        config.build_settings['OTHER_LDFLAGS'] = values
      end
    end
    user_project.save
  end
end
